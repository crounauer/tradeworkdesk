# Monitoring & Error Tracking
# Set these to enable Sentry error tracking and performance monitoring

# Frontend Sentry Configuration
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Backend Sentry Configuration (Fly.io secrets)
# SENTRY_DSN=
# SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Note: You can use the same Sentry project DSN for both frontend and backend.
# Create a Sentry project at https://sentry.io and copy the DSN here.

# Application version (for Sentry release tracking)
VITE_APP_VERSION=1.0.0
